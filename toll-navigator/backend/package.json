{
  "name": "toll-navigator-backend",
  "version": "0.2.0",
  "description": "Toll Navigator API — truck toll calculator",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch --experimental-sqlite src/server.js",
    "test": "jest --testEnvironment node --forceExit"
  },
  "dependencies": {
    "apple-signin-auth": "^1.7.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.0.0",
    "google-auth-library": "^9.14.2",
    "jsonwebtoken": "^9.0.2",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "clearMocks": true,
    "testTimeout": 15000
  }
}
