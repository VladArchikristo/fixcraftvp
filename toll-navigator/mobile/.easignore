# EAS Build ignore — exclude files not needed in cloud build

# Tests
__tests__/
*.test.js
*.test.ts
*.spec.js
*.spec.ts
jest.config.js

# Documentation
*.md
LICENSE

# Dev tools
.vscode/
.idea/
.claude/

# SVG sources (PNGs already generated)
assets/*.svg

# Git
.git/
.gitignore

# Environment (handled by eas.json env)
.env
.env.local
.env.production

# Google Service Account (sensitive, set via EAS secrets)
google-service-account.json

# macOS
.DS_Store

# Backend (not needed in mobile build)
../backend/

# Sharp / dev dependencies build artifacts
.cache/
